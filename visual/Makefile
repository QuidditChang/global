	for dir in "$(DESTDIR)$(bindir)" "$(DESTDIR)$(bindir)" "$(DESTDIR)$(visualdir)" "$(DESTDIR)$(visualdir)"; do \
	  test -z "$$dir" || $(mkdir_p) "$$dir"; \
	done
