#!/bin/bash
#----------------------------------------------------
# Example SLURM job script to run hybrid applications 
# (MPI/OpenMP or MPI/pthreads) on TACC's Stampede 
# system.
#----------------------------------------------------
#SBATCH -J mpi_job     # Job name
#SBATCH -o stdout.o%j # Name of stdout output file(%j expands to jobId) 
#SBATCH -e stderr.o%j # Name of stderr output file(%j expands to jobId)
#SBATCH -p normal         # Serial queue for serial and MPI jobs
#SBATCH -N 144            # Total number of nodes requested (16 cores/node)
#SBATCH -n 4608           # Total number of mpi tasks requested
#SBATCH -t 1:00:00       # Run time (hh:mm:ss) - 1.5 hours
# The next line is required if the user has more than one project
#SBATCH -A TG-EAR160027  # <-- Allocation name to charge job against

export PATH=/home1/02505/hujs/mypython/bin:$PATH

restart=1
datadir=~/scratch/GlobalModel257_Tracer_plume_output

if [ $restart -eq 0 ]; then
/home1/02505/hujs/AssimDepth_CitcomS-3.0.3_global_plasticity_Tracer_test_v3.3/bin/citcoms lab257x129.cfg
else
    timestep=`ls -t $datadir/DATA/0/global.chkpt.* | head -1 | awk -F . '{print $4}' | awk '{print $1/1.0}'`
    age=`awk -v tp=$timestep '{if($1==tp) print 230-$2/7.7748e-7}' $datadir/DATA/0/global.time | tail -1`
    sed -e "/^solution/a\solution_cycles_init = $timestep" -e "/^solution/d" cp1.cfg > cp2.cfg
    dos2unix cp2.cfg
    echo $age | xargs -I {} sed -e '/^start_age/a\start_age = {}' -e '/^start_age/d' cp2.cfg > cp3.cfg
    dos2unix cp3.cfg
    #sed -r "s/\[0m//g" cp3.cfg > cp2.cfg
    #rm cp3.cfg
    mv cp3.cfg cp2.cfg
    cp $datadir/DATA/*/global.chkpt.*.$timestep $datadir/Restart
/home1/02505/hujs/AssimDepth_CitcomS-3.0.3_global_plasticity_Tracer_test_v3.3/bin/citcoms cp2.cfg
fi

