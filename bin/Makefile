	then mv -f "$(DEPDIR)/mpipycitcoms-pycitcoms.Tpo" "$(DEPDIR)/mpipycitcoms-pycitcoms.Po"; else rm -f "$(DEPDIR)/mpipycitcoms-pycitcoms.Tpo"; exit 1; fi
